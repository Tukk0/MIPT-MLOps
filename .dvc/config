[core]
    autostage = true
[dvc]
    version = 4
    cache = cache
    cache.level = 2

[cache]
    dir = .dvc/cache
    shared = true

[remote "data"]
    url = .dvc/cache-data
    shared = true

[remote "models"]
    url = .dvc/cache-models
    shared = true

[cache "data"]
    dir = .dvc/cache-data

[cache "models"]
    dir = .dvc/cache-models

[core]
    remote = "data"

[remote "default"]
    url = .dvc/cache-default
    shared = true
